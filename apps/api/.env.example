# Schism API - copy to .env and fill in values

# Server
PORT=8000
FRONTEND_URL=http://localhost:3000

# Database
SCHISM_DATABASE_URL=sqlite:///./data/schism.db

# Vector store (optional - set SCHISM_ENABLE_QDRANT=true to use)
SCHISM_ENABLE_QDRANT=false
SCHISM_QDRANT_URL=http://localhost:6333
SCHISM_QDRANT_COLLECTION=schism_claims

# LLM providers - users supply their own keys via API headers
# These are NOT used server-side. Keys come from X-Api-Key header.
# Set a default provider for the health check only:
SCHISM_DEFAULT_PROVIDER=mock

# Embedding
SCHISM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Pipeline limits
SCHISM_DEFAULT_MAX_RESULTS=25
SCHISM_CONTRADICTION_THRESHOLD=0.6
SCHISM_CLAIM_CONCURRENCY=4
SCHISM_SCORING_CONCURRENCY=4
SCHISM_JOB_TIMEOUT_MINUTES=15
SCHISM_QUERY_CACHE_HOURS=6
SCHISM_ANALYSIS_CACHE_HOURS=24

# CORS
SCHISM_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=human
